<Window x:Class="CleanWizard.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:CleanWizard.Core.Models;assembly=CleanWizard.Core"
        xmlns:vm="clr-namespace:CleanWizard.App.ViewModels"
        xmlns:views="clr-namespace:CleanWizard.App.Views"
        mc:Ignorable="d"
        Title="CleanWizard"
        Height="750" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <!-- DataTemplates for Navigation -->
        <DataTemplate DataType="{x:Type vm:SystemCheckViewModel}">
            <views:SystemCheckView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:WizardViewModel}">
            <views:WizardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SummaryViewModel}">
            <views:SummaryView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}">
            <DockPanel>
                <!-- Logo -->
                <StackPanel DockPanel.Dock="Top" Margin="16,24,16,16">
                    <TextBlock Text="CleanWizard"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Sicher bereinigen. Klar geführt."
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Score Display -->
                <Border DockPanel.Dock="Top"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8"
                        Margin="12,0,12,16"
                        Padding="12,10">
                    <StackPanel>
                        <TextBlock Text="Gesamtfortschritt"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock FontSize="28" FontWeight="Bold"
                                       Text="{Binding WizardViewModel.CurrentScore}"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock FontSize="16" Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding WizardViewModel.MaxScore, StringFormat=/{0}}"
                                       VerticalAlignment="Bottom" Margin="2,0,0,4"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding WizardViewModel.CurrentScore}"
                                     Maximum="{Binding WizardViewModel.MaxScore}"
                                     Height="4" Margin="0,4,0,0"
                                     Foreground="{StaticResource AccentBrush}"
                                     Background="{StaticResource BorderBrush}">
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border CornerRadius="2" Background="{TemplateBinding Background}">
                                        <Border x:Name="PART_Indicator"
                                                HorizontalAlignment="Left"
                                                CornerRadius="2"
                                                Background="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <StackPanel DockPanel.Dock="Top" Margin="16,0,16,0">
                    <TextBlock Text="Ablauf"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,8"/>
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateSystemCheckCommand}"
                            Tag="{Binding IsSystemCheckActive}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="{StaticResource SidebarActiveBrush}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="1"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Start-Check" VerticalAlignment="Center"/>
                                <TextBlock Text="Prüfen und Einstieg wählen"
                                           FontSize="11"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateWizardCommand}"
                            Tag="{Binding IsWizardActive}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="{StaticResource SidebarActiveBrush}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="2"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Assistent" VerticalAlignment="Center"/>
                                <TextBlock Text="Schritte sicher abarbeiten"
                                           FontSize="11"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SidebarButtonStyle}"
                            Command="{Binding NavigateSummaryCommand}"
                            Tag="{Binding IsSummaryActive}">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="24"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="{StaticResource SidebarActiveBrush}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="3"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                            <StackPanel>
                                <TextBlock Text="Abschluss" VerticalAlignment="Center"/>
                                <TextBlock Text="Ergebnis und offene Punkte"
                                           FontSize="11"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"/>
                            </StackPanel>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Grid DockPanel.Dock="Top" Height="1" Background="{StaticResource BorderBrush}" Margin="12,12"/>

                <!-- Mode Switch -->
                <StackPanel DockPanel.Dock="Top" Margin="16,0">
                    <TextBlock Text="Optionen" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                    <CheckBox Content="Erweiterte Hinweise"
                              Style="{StaticResource ModernCheckBoxStyle}"
                              IsChecked="{Binding IsExpertMode}"
                              Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="Darstellung" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,6"/>
                    <ToggleButton Content="Dunkles Design"
                                  Style="{StaticResource ToggleButtonStyle}"
                                  IsChecked="{Binding IsDarkMode}"
                                  HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Version -->
                <TextBlock DockPanel.Dock="Bottom"
                           Text="{x:Static models:AppVersion.Display}"
                           FontSize="10"
                           Foreground="{StaticResource TextMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
            </DockPanel>
        </Border>

        <!-- Main Content -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentView}"/>

        <!-- Resume Prompt Overlay -->
        <Grid Grid.ColumnSpan="2"
              Background="#99000000"
              Visibility="{Binding ShowResumePrompt, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="520"
                    Padding="20"
                    CornerRadius="10"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Gespeicherten Durchlauf fortsetzen?"
                               Style="{StaticResource SubheadingStyle}"
                               FontSize="20"/>
                    <TextBlock Text="{Binding ResumeInfoText}"
                               Style="{StaticResource BodyTextStyle}"
                               Margin="0,8,0,14"
                               TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ContinueSavedProgressCommand}"
                                Margin="0,0,8,0">
                            Fortsetzen
                        </Button>
                        <Button Style="{StaticResource WarningButtonStyle}"
                                Command="{Binding StartFreshProgressCommand}">
                            Neu beginnen
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
