<UserControl x:Class="CleanWizard.App.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24">

            <!-- Header -->
            <TextBlock Text="📊 Zusammenfassung"
                       Style="{StaticResource HeadingStyle}"
                       FontSize="28"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Dein persönlicher Systembereinigungsbericht"
                       Style="{StaticResource BodyTextStyle}"
                       FontSize="14"
                       Margin="0,0,0,24"/>

            <!-- Score Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Leistungswert"
                                   Style="{StaticResource SubheadingStyle}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                            <TextBlock FontSize="48" FontWeight="Bold">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding ScoreColor}"/>
                                </TextBlock.Foreground>
                                <TextBlock.Text>
                                    <Binding Path="ScorePercent" StringFormat="{}{0:0}%"/>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBlock Text="{Binding ScoreRating}"
                                       FontSize="20"
                                       VerticalAlignment="Bottom"
                                       Margin="12,0,0,8"
                                       FontWeight="SemiBold">
                                <TextBlock.Foreground>
                                    <SolidColorBrush Color="{Binding ScoreColor}"/>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </StackPanel>
                        <ProgressBar Value="{Binding ScorePercent}"
                                     Maximum="100"
                                     Height="8"
                                     Width="300"
                                     HorizontalAlignment="Left">
                            <ProgressBar.Foreground>
                                <SolidColorBrush Color="{Binding ScoreColor}"/>
                            </ProgressBar.Foreground>
                            <ProgressBar.Background>
                                <SolidColorBrush Color="#E0E0E0"/>
                            </ProgressBar.Background>
                            <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border CornerRadius="4" Background="{TemplateBinding Background}">
                                        <Border x:Name="PART_Indicator"
                                                HorizontalAlignment="Left"
                                                CornerRadius="4"
                                                Background="{TemplateBinding Foreground}"/>
                                    </Border>
                                </ControlTemplate>
                            </ProgressBar.Template>
                        </ProgressBar>
                    </StackPanel>

                    <!-- Stats -->
                    <UniformGrid Grid.Column="1" Columns="2" Margin="16,0,0,0">
                        <Border CornerRadius="8" Background="#E8F5E9" Margin="4" Padding="12,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding CompletedCount}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Erledigt" Style="{StaticResource CaptionStyle}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="8" Background="#FFF3E0" Margin="4" Padding="12,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding LaterCount}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource WarningBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Später" Style="{StaticResource CaptionStyle}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="8" Background="#F5F5F5" Margin="4" Padding="12,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding SkippedCount}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Übersprungen" Style="{StaticResource CaptionStyle}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border CornerRadius="8" Background="#E3F2FD" Margin="4" Padding="12,8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PendingCount}"
                                           FontSize="24" FontWeight="Bold"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Ausstehend" Style="{StaticResource CaptionStyle}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>

            <!-- Before/After Comparison -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                    Visibility="{Binding HasComparisonData, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="📉 Vorher / Nachher"
                               Style="{StaticResource SubheadingStyle}"
                               Margin="0,0,0,10"/>
                    <UniformGrid Columns="4">
                        <Border CornerRadius="8" Background="#F5F5F5" Margin="4" Padding="10">
                            <StackPanel>
                                <TextBlock Text="⚡ CPU-Auslastung" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0">
                                    <Run Text="{Binding CpuBeforeText}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding CpuAfterText}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding CpuDeltaText}"
                                           FontSize="12"
                                           Foreground="{Binding CpuDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="V" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="0" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding CpuBeforePercent}"
                                                 Foreground="#BDBDBD"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="N" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="2" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding CpuAfterPercent}"
                                                 Foreground="{Binding CpuDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Autostart -->
                        <Border CornerRadius="8" Background="#F5F5F5" Margin="4" Padding="10">
                            <StackPanel>
                                <TextBlock Text="🚀 Autostart-Einträge" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0">
                                    <Run Text="{Binding AutostartBefore}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding AutostartAfter}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding AutostartDeltaText}"
                                           FontSize="12"
                                           Foreground="{Binding AutostartDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="V" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="0" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding AutostartBeforePercent}"
                                                 Foreground="#BDBDBD"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="N" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="2" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding AutostartAfterPercent}"
                                                 Foreground="{Binding AutostartDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Free Disk -->
                        <Border CornerRadius="8" Background="#F5F5F5" Margin="4" Padding="10">
                            <StackPanel>
                                <TextBlock Text="💾 Freier Speicher" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0">
                                    <Run Text="{Binding FreeDiskBeforeText}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding FreeDiskAfterText}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding FreeDiskDeltaText}"
                                           FontSize="12"
                                           Foreground="{Binding FreeDiskDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="V" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="0" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding FreeDiskBeforePercent}"
                                                 Foreground="#BDBDBD"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="N" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="2" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding FreeDiskAfterPercent}"
                                                 Foreground="{Binding FreeDiskDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Used RAM -->
                        <Border CornerRadius="8" Background="#F5F5F5" Margin="4" Padding="10">
                            <StackPanel>
                                <TextBlock Text="🧠 Genutzter RAM" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock FontSize="13" FontWeight="SemiBold" Margin="0,4,0,0">
                                    <Run Text="{Binding UsedRamBeforeText}"/>
                                    <Run Text=" → "/>
                                    <Run Text="{Binding UsedRamAfterText}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding UsedRamDeltaText}"
                                           FontSize="12"
                                           Foreground="{Binding UsedRamDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="3"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="V" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="0" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding UsedRamBeforePercent}"
                                                 Foreground="#BDBDBD"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="N" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <ProgressBar Grid.Row="2" Grid.Column="1"
                                                 Style="{StaticResource MiniBarStyle}"
                                                 Value="{Binding UsedRamAfterPercent}"
                                                 Foreground="{Binding UsedRamDeltaColor, Converter={StaticResource StringToColorConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- Step Summary List -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Schritt-Übersicht"
                               Style="{StaticResource SubheadingStyle}"
                               Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding StepSummaries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="18"
                                               VerticalAlignment="Center"/>

                                    <StackPanel Grid.Column="1" Margin="8,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Note}"
                                                   Style="{StaticResource CaptionStyle}"
                                                   Visibility="{Binding Note, Converter={StaticResource NullToCollapsedConverter}}"/>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Category}"
                                               Style="{StaticResource CaptionStyle}"
                                               Margin="8,0"/>

                                    <Border Grid.Column="3"
                                            CornerRadius="10"
                                            Padding="8,3"
                                            Margin="4,0"
                                            VerticalAlignment="Center">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding StatusColor}"/>
                                        </Border.Background>
                                        <TextBlock Text="{Binding StatusText}"
                                                   Foreground="White"
                                                   FontSize="11"/>
                                    </Border>

                                    <TextBlock Grid.Column="4"
                                               Text="{Binding Score, StringFormat=⭐{0}}"
                                               Style="{StaticResource CaptionStyle}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Export Buttons -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="📤 Bericht exportieren"
                               Style="{StaticResource SubheadingStyle}"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportTxtCommand}"
                                Margin="0,0,8,0">
                            📄 Als Textdatei (TXT)
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportJsonCommand}">
                            📋 Als JSON
                        </Button>
                        <Button Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportLogCommand}"
                                Margin="8,0,0,0">
                            🧾 Log exportieren
                        </Button>
                    </StackPanel>

                    <TextBlock Text="{Binding ExportMessage}"
                               Foreground="{StaticResource SuccessBrush}"
                               FontSize="12"
                               Margin="0,8,0,0"
                               Visibility="{Binding ExportMessage, Converter={StaticResource NullToCollapsedConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <StackPanel Orientation="Horizontal">
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding RestartCommand}"
                        Margin="0,0,8,0">
                    🔄 Assistent neu starten
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
