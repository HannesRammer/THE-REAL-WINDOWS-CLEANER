<UserControl x:Class="CleanWizard.App.Views.WizardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Progress Bar Header -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{Binding ProgressText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text=" | "
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"/>
                        <TextBlock Text="{Binding CurrentStepVm.Category}"
                                   FontSize="13"
                                   Foreground="{StaticResource PrimaryBrush}"/>
                    </StackPanel>
                    <ProgressBar Value="{Binding ProgressPercent}"
                                 Maximum="100"
                                 Style="{StaticResource WizardProgressBarStyle}"
                                 Width="400"
                                 HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Score Badge -->
                <Border Grid.Column="1"
                        Background="{StaticResource PrimaryBrush}"
                        CornerRadius="16"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1} Punkte">
                                    <Binding Path="CurrentScore"/>
                                    <Binding Path="MaxScore"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Step Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid Margin="32,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Main Step Content -->
                <StackPanel Grid.Column="0" Margin="0,0,24,0">

                    <!-- Step Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="{Binding CurrentStepVm.Icon}"
                                   FontSize="32"
                                   Margin="0,0,12,0"
                                   VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentStepVm.Title}"
                                       Style="{StaticResource HeadingStyle}"
                                       Margin="0"/>
                            <StackPanel Orientation="Horizontal">
                                <Border CornerRadius="10" Padding="8,3" Margin="0,0,8,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#E3F2FD"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding CurrentStepVm.DifficultyText}"
                                               FontSize="11"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </Border>
                                <Border CornerRadius="10" Padding="8,3">
                                    <Border.Background>
                                        <SolidColorBrush Color="#FFF8E1"/>
                                    </Border.Background>
                                    <TextBlock Text="{Binding CurrentStepVm.RiskLevelText}"
                                               FontSize="11">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding CurrentStepVm.RiskColor}"/>
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="{Binding CurrentStepVm.Description}"
                               Style="{StaticResource BodyTextStyle}"
                               FontSize="14"
                               Margin="0,0,0,16"/>

                    <Border Background="#FFEBEE"
                            BorderBrush="{StaticResource ErrorBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10"
                            Margin="0,0,0,16"
                            Visibility="{Binding IsEmergencyModeActive, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="Schnellmodus aktiv. Es werden nur die wichtigsten Schritte gezeigt."
                                   Foreground="#B71C1C"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"/>
                    </Border>

                    <!-- Step Screenshot / Visual Aid -->
                    <Border Style="{StaticResource CardStyle}"
                            Margin="0,0,0,16"
                            Visibility="{Binding CurrentStepVm.ImagePath, Converter={StaticResource NullToCollapsedConverter}}">
                        <StackPanel>
                            <TextBlock Text="Beispielansicht"
                                       Style="{StaticResource SubheadingStyle}"
                                       Margin="0,0,0,8"/>
                            <Image Source="{Binding CurrentStepVm.ImagePath}"
                                   Height="220"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- Kompakt-Checkliste -->
                    <Border Style="{StaticResource InfoBoxStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Was jetzt zu tun ist"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding CurrentStepVm.CompactChecklist}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Knowledge Panel (nur erweitert) -->
                    <Expander Header="Warum das sinnvoll ist"
                              IsExpanded="True"
                              Margin="0,0,0,8"
                              Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="0,0,6,6"
                                Padding="12">
                            <TextBlock Text="{Binding CurrentStepVm.WhyImportant}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Expander>

                    <Expander Header="Was sich dadurch verbessert"
                              Margin="0,0,0,8"
                              Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="0,0,6,6"
                                Padding="12">
                            <TextBlock Text="{Binding CurrentStepVm.WhatItDoes}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Expander>

                    <Expander Header="Empfohlene Vorgehensweise"
                              Margin="0,0,0,8"
                              Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="0,0,6,6"
                                Padding="12">
                            <TextBlock Text="{Binding CurrentStepVm.RecommendedApproach}"
                                       Style="{StaticResource BodyTextStyle}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Expander>

                    <!-- Warning Box: What NOT to do -->
                    <Border Style="{StaticResource WarningBoxStyle}" Margin="0,8,0,8">
                        <StackPanel>
                            <TextBlock Text="Worauf du achten solltest"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding CurrentStepVm.WhatNotToDo}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Foreground="#E65100"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Risks Box -->
                    <Border Background="#FFF3E0"
                            BorderBrush="#FFCC02"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,0,0,16">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" FontSize="16" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding CurrentStepVm.Risks}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Foreground="#E65100"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Simple Explanation Toggle -->
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ToggleSimpleExplanationCommand}"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8">
                        Einfach erklärt
                    </Button>

                    <!-- Simple Explanation Panel -->
                    <Border Background="#E8F5E9"
                            BorderBrush="{StaticResource SuccessBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            Margin="0,0,0,16"
                            Visibility="{Binding ShowSimpleExplanation, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Kurz erklärt"
                                       FontWeight="SemiBold"
                                       Foreground="#2E7D32"
                                       Margin="0,0,0,6"/>
                            <TextBlock Text="{Binding CurrentStepVm.SimpleExplanation}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Foreground="#1B5E20"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Expert Details -->
                    <Expander Header="Technische Details"
                              Margin="0,0,0,16"
                              Visibility="{Binding IsExpertMode, Converter={StaticResource BoolToVisibilityConverter}}">
                        <Border Background="{StaticResource CardBrush}"
                                CornerRadius="0,0,6,6"
                                Padding="12">
                            <TextBlock Text="{Binding CurrentStepVm.ExpertDetails}"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontFamily="Consolas"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </Expander>

                    <!-- Note Field -->
                    <TextBlock Text="Eigene Notiz"
                               Style="{StaticResource SubheadingStyle}"/>
                    <TextBox Text="{Binding CurrentStepVm.UserNote, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource NoteTextBoxStyle}"
                             Height="60"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Margin="0,4,0,0"/>

                </StackPanel>

                <!-- Right Panel: Check Mode + Quick Actions -->
                <StackPanel Grid.Column="1">

                    <!-- Status Checkboxes -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Schrittstatus"
                                       Style="{StaticResource SubheadingStyle}"
                                       Margin="0,0,0,8"/>

                            <CheckBox Content="Erledigt"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      IsChecked="{Binding CurrentStepVm.IsCompleted}"
                                      IsEnabled="{Binding CurrentStepVm.CanMarkCompleted}"
                                      Command="{Binding MarkCompletedCommand}"
                                      Foreground="{StaticResource SuccessBrush}"/>

                            <CheckBox Content="Übersprungen"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      IsChecked="{Binding CurrentStepVm.IsSkipped}"
                                      Foreground="{StaticResource TextSecondaryBrush}"/>

                            <CheckBox Content="Später erledigen"
                                      Style="{StaticResource ModernCheckBoxStyle}"
                                      IsChecked="{Binding CurrentStepVm.IsLater}"
                                      Foreground="{StaticResource WarningBrush}"/>

                            <Separator Margin="0,8"/>

                            <TextBlock Text="{Binding CurrentStepVm.ScoreValue, StringFormat={}{0} Punkte in diesem Schritt}"
                                       Style="{StaticResource CaptionStyle}"
                                       FontSize="12"/>

                            <Border Background="#FFEBEE"
                                    BorderBrush="{StaticResource ErrorBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,8,0,0"
                                    Visibility="{Binding CurrentStepVm.RequiresSafetyAcknowledgement, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Bestätigung erforderlich"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Foreground="#B71C1C"/>
                                    <CheckBox Content="Ich habe eine Sicherung oder einen Wiederherstellungspunkt."
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,6,0,0"
                                              IsChecked="{Binding CurrentStepVm.IsSafetyBackupConfirmed}"/>
                                    <CheckBox Content="Ich kenne die Auswirkungen dieses Schritts."
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,4,0,0"
                                              IsChecked="{Binding CurrentStepVm.IsSafetyImpactConfirmed}"/>
                                    <CheckBox Content="Ich weiß, wie ich die Änderung bei Bedarf rückgängig mache."
                                              Style="{StaticResource ModernCheckBoxStyle}"
                                              Margin="0,4,0,0"
                                              IsChecked="{Binding CurrentStepVm.IsSafetyRecoveryConfirmed}"/>
                                </StackPanel>
                            </Border>

                            <Button Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding UndoLastChangeCommand}"
                                    IsEnabled="{Binding CanUndoCurrentStep}"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Stretch">
                                Letzte Änderung rückgängig
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Quick Launch Buttons -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16"
                            Visibility="{Binding CurrentStepVm.HasActions, Converter={StaticResource BoolToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Jetzt ausführen"
                                       Style="{StaticResource SubheadingStyle}"
                                       Margin="0,0,0,8"/>

                            <Border Background="{Binding ToolFeedbackBackground, Converter={StaticResource StringToColorConverter}}"
                                    BorderBrush="{Binding ToolFeedbackBorder, Converter={StaticResource StringToColorConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding ToolFeedbackMessage, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock Text="{Binding ToolFeedbackMessage}"
                                           Foreground="{Binding ToolFeedbackForeground, Converter={StaticResource StringToColorConverter}}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </Border>

                            <Border Background="#F3F6FB"
                                    BorderBrush="#D4DCEB"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding ToolSetupStateText, Converter={StaticResource NullToCollapsedConverter}}">
                                <TextBlock FontSize="12"
                                           Text="{Binding ToolSetupStateText}"
                                           Foreground="{Binding ToolSetupStateColor, Converter={StaticResource StringToColorConverter}}"/>
                            </Border>

                            <Border Background="#F5F7FB"
                                    BorderBrush="#D4DCEB"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding CurrentStepVm.HasSetupFlow, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Empfohlene Reihenfolge"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="{StaticResource PrimaryBrush}"
                                               Margin="0,0,0,4"/>
                                    <TextBlock Text="Arbeite diese drei Schritte nacheinander ab: prüfen, installieren, öffnen."
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F5F7FB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,0,6"
                                    Padding="10"
                                    Visibility="{Binding CurrentStepVm.SetupCheckAction, Converter={StaticResource NullToCollapsedConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#E3F2FD" Margin="0,0,8,0">
                                            <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="Prüfen"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding DataContext.RunToolActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding CurrentStepVm.SetupCheckAction}"
                                            IsEnabled="{Binding DataContext.IsToolActionBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="{Binding CurrentStepVm.SetupCheckAction.Label}"/>
                                    </Button>
                                    <TextBlock Text="{Binding CurrentStepVm.SetupCheckAction.Description}"
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F5F7FB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,0,6"
                                    Padding="10"
                                    Visibility="{Binding CurrentStepVm.SetupInstallAction, Converter={StaticResource NullToCollapsedConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#E8F5E9" Margin="0,0,8,0">
                                            <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="Installieren"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource SuccessButtonStyle}"
                                            Command="{Binding DataContext.RunToolActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding CurrentStepVm.SetupInstallAction}"
                                            IsEnabled="{Binding DataContext.IsToolActionBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="{Binding CurrentStepVm.SetupInstallAction.Label}"/>
                                    </Button>
                                    <TextBlock Text="{Binding CurrentStepVm.SetupInstallAction.Description}"
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#F5F7FB"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Margin="0,0,0,8"
                                    Padding="10"
                                    Visibility="{Binding CurrentStepVm.SetupOpenAction, Converter={StaticResource NullToCollapsedConverter}}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="22" Height="22" CornerRadius="11" Background="#FFF3E0" Margin="0,0,8,0">
                                            <TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource WarningBrush}" FontWeight="SemiBold"/>
                                        </Border>
                                        <TextBlock Text="Öffnen"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding DataContext.RunToolActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding CurrentStepVm.SetupOpenAction}"
                                            IsEnabled="{Binding DataContext.IsToolActionBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0">
                                        <TextBlock Text="{Binding CurrentStepVm.SetupOpenAction.Label}"/>
                                    </Button>
                                    <TextBlock Text="{Binding CurrentStepVm.SetupOpenAction.Description}"
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#E8F5E9"
                                    BorderBrush="#A5D6A7"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="8"
                                    Margin="0,0,0,8"
                                    Visibility="{Binding CurrentStepVm.PrimaryToolAction, Converter={StaticResource NullToCollapsedConverter}}">
                                <StackPanel>
                                    <TextBlock Text="Am sinnvollsten zuerst"
                                               Foreground="#1B5E20"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>
                                    <Button Style="{StaticResource SuccessButtonStyle}"
                                            Command="{Binding DataContext.RunToolActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding CurrentStepVm.PrimaryToolAction}"
                                            IsEnabled="{Binding DataContext.IsToolActionBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                            HorizontalAlignment="Stretch">
                                        <TextBlock Text="{Binding CurrentStepVm.PrimaryToolAction.Label}"/>
                                    </Button>
                                    <TextBlock Text="{Binding CurrentStepVm.PrimaryToolAction.Description}"
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                    <TextBlock Text="{Binding CurrentStepVm.PrimaryToolAction.SafetyHint}"
                                               Foreground="#E65100"
                                               FontSize="11"
                                               TextWrapping="Wrap"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding CurrentStepVm.PrimaryToolAction.SafetyHint, Converter={StaticResource NullToCollapsedConverter}}"/>
                                </StackPanel>
                            </Border>

                            <ItemsControl ItemsSource="{Binding CurrentStepVm.AdditionalToolActions}"
                                          Visibility="{Binding CurrentStepVm.HasAdditionalToolActions, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#F5F7FB"
                                                BorderBrush="{StaticResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Margin="0,0,0,6"
                                                Padding="8">
                                            <StackPanel>
                                                <Button Style="{StaticResource SecondaryButtonStyle}"
                                                        Command="{Binding DataContext.RunToolActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        IsEnabled="{Binding DataContext.IsToolActionBusy, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolConverter}}"
                                                        HorizontalAlignment="Stretch">
                                                    <TextBlock Text="{Binding Label}"/>
                                                </Button>
                                                <TextBlock Text="{Binding Description}"
                                                           Style="{StaticResource CaptionStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,0"/>
                                                <TextBlock Text="{Binding SafetyHint}"
                                                           Foreground="#E65100"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"
                                                           Visibility="{Binding SafetyHint, Converter={StaticResource NullToCollapsedConverter}}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="Für diesen Schritt musst du hier nichts zusätzlich öffnen."
                                       Style="{StaticResource CaptionStyle}"
                                       Visibility="{Binding CurrentStepVm.HasToolActions, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>

                    <!-- Step Info Card -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Einordnung"
                                       Style="{StaticResource SubheadingStyle}"
                                       Margin="0,0,0,8"/>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Schwierigkeit" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentStepVm.DifficultyText}"
                                           Style="{StaticResource CaptionStyle}"
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Risiko" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentStepVm.RiskLevelText}"
                                           Style="{StaticResource CaptionStyle}">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding CurrentStepVm.RiskColor}"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Bereich" Style="{StaticResource CaptionStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding CurrentStepVm.Category}"
                                           Style="{StaticResource CaptionStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>

            </Grid>
        </ScrollViewer>

        <!-- Navigation Footer -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="24,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Back + Skip -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding PreviousCommand}"
                            IsEnabled="{Binding CanGoPrevious}"
                            Margin="0,0,8,0">
                        Zurück
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SkipCommand}"
                            Margin="0,0,8,0">
                        Überspringen
                    </Button>
                    <Button Style="{StaticResource WarningButtonStyle}"
                            Command="{Binding MarkLaterCommand}">
                        Für später merken
                    </Button>
                </StackPanel>

                <!-- Right: Next/Finish -->
                <Button Grid.Column="2"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding NextCommand}"
                        Padding="24,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Weiter"
                                   Visibility="{Binding IsLastStep, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                        <TextBlock Text="Abschließen"
                                   Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Border>

    </Grid>
</UserControl>
