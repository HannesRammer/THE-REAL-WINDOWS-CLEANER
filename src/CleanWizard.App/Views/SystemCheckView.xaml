<UserControl x:Class="CleanWizard.App.Views.SystemCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Loading Overlay -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock Text="System wird analysiert..."
                           FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">

                <!-- Header -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="System-Check"
                               Style="{StaticResource HeadingStyle}"
                               FontSize="28"/>
                    <TextBlock Text="Analyse deines Systems vor dem Start"
                               Style="{StaticResource BodyTextStyle}"
                               FontSize="14"/>
                </StackPanel>

                <!-- Emergency Mode Banner -->
                <Border Background="#FFEBEE"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsEmergencyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚨" FontSize="20" Margin="0,0,12,0"/>
                        <StackPanel>
                            <TextBlock Text="Notfall-Modus empfohlen!"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding RecommendationText}"
                                       Foreground="#B71C1C"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- System Status Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Systemzustand"
                                       Style="{StaticResource SubheadingStyle}"/>
                            <TextBlock Text="{Binding RecommendationText}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                CornerRadius="20"
                                Padding="16,8"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding SystemStatusColor}"/>
                            </Border.Background>
                            <TextBlock Text="{Binding SystemStatusText}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Info Cards Grid -->
                <UniformGrid Columns="3" Margin="0,0,0,16">

                    <!-- Windows Version -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="🪟" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Windows"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding WindowsVersionText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- CPU -->
                    <Border Style="{StaticResource CardStyle}" Margin="4,0,4,8">
                        <StackPanel>
                            <TextBlock Text="⚡" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Prozessor"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding CpuText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Style="{StaticResource CardStyle}" Margin="8,0,0,8">
                        <StackPanel>
                            <TextBlock Text="🧠" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Arbeitsspeicher"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding RamText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Drive Type -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="💾" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Laufwerkstyp"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding DriveTypeText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Free Disk Space -->
                    <Border Style="{StaticResource CardStyle}" Margin="4,0,4,8">
                        <StackPanel>
                            <TextBlock Text="📁" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Freier Speicher"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding FreeDiskText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Autostart Count -->
                    <Border Style="{StaticResource CardStyle}" Margin="8,0,0,8">
                        <StackPanel>
                            <TextBlock Text="🚀" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Autostart-Programme"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding AutostartCountText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Running Processes -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,8,8">
                        <StackPanel>
                            <TextBlock Text="📈" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Laufende Prozesse"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding RunningProcessesText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Last Windows Update -->
                    <Border Style="{StaticResource CardStyle}" Margin="4,0,4,8">
                        <StackPanel>
                            <TextBlock Text="🪟" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Letztes Update"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding LastWindowsUpdateText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Last Malware Scan -->
                    <Border Style="{StaticResource CardStyle}" Margin="8,0,0,8">
                        <StackPanel>
                            <TextBlock Text="🛡️" FontSize="24" Margin="0,0,0,8"/>
                            <TextBlock Text="Letzter Malware-Scan"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding LastMalwareScanText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Recommendation -->
                <Border Style="{StaticResource InfoBoxStyle}"
                        Margin="0,0,0,24"
                        Visibility="{Binding IsEmergencyMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💡" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Top"/>
                        <StackPanel>
                            <TextBlock Text="Empfehlung"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding RecommendationText}"
                                       Foreground="#1565C0"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Start Button -->
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding StartWizardCommand}"
                        HorizontalAlignment="Left"
                        FontSize="16"
                        Padding="32,14">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧭  " FontSize="18"/>
                        <TextBlock Text="Wizard starten" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
