<UserControl x:Class="CleanWizard.App.Views.SystemCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <!-- Loading Overlay -->
        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Prüfung läuft"
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Start-Check läuft..."
                           FontSize="18"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <ScrollViewer Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32,24">

                <!-- Header -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Start-Check"
                               Style="{StaticResource HeadingStyle}"
                               FontSize="28"/>
                    <TextBlock Text="Wir prüfen kurz, wo du am sinnvollsten beginnst."
                               Style="{StaticResource BodyTextStyle}"
                               FontSize="14"/>
                </StackPanel>

                <!-- Emergency Mode Banner -->
                <Border Background="#FFEBEE"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsEmergencyMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel>
                            <TextBlock Text="Schnellmodus empfohlen"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontSize="14"/>
                            <TextBlock Text="{Binding RecommendationText}"
                                       Foreground="#B71C1C"
                                       FontSize="12"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Error Banner -->
                <Border Background="#FFEBEE"
                        BorderBrush="{StaticResource ErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16,12"
                        Margin="0,0,0,16"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Start-Check konnte nicht vollständig geladen werden"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource ErrorBrush}"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#B71C1C"
                                   FontSize="12"
                                   Margin="0,4,0,8"
                                   TextWrapping="Wrap"/>
                        <Button Style="{StaticResource WarningButtonStyle}"
                                Command="{Binding RetrySystemCheckCommand}"
                                HorizontalAlignment="Left">
                            Erneut prüfen
                        </Button>
                    </StackPanel>
                </Border>

                <!-- System Status Card -->
                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Kurzfazit"
                                       Style="{StaticResource SubheadingStyle}"/>
                            <TextBlock Text="{Binding RecommendationText}"
                                       Style="{StaticResource BodyTextStyle}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                CornerRadius="20"
                                Padding="16,8"
                                VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="{Binding SystemStatusColor}"/>
                            </Border.Background>
                            <TextBlock Text="{Binding SystemStatusText}"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       FontSize="14"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="So läuft es ab"
                                   Style="{StaticResource SubheadingStyle}"
                                   Margin="0,0,0,10"/>
                        <UniformGrid Columns="3">
                            <Border Background="#F5F7FB" CornerRadius="8" Margin="0,0,8,0" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="1"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="Prüfen"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,4"/>
                                    <TextBlock Text="Wir lesen den aktuellen Zustand deines PCs aus."
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F5F7FB" CornerRadius="8" Margin="4,0" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="2"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="Führen"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,4"/>
                                    <TextBlock Text="Der Assistent führt dich sicher durch die passenden Schritte."
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F5F7FB" CornerRadius="8" Margin="8,0,0,0" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="3"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                    <TextBlock Text="Abschließen"
                                               FontWeight="SemiBold"
                                               Margin="0,4,0,4"/>
                                    <TextBlock Text="Am Ende siehst du Ergebnis, offene Punkte und Exporte."
                                               Style="{StaticResource CaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <!-- Info Cards -->
                <UniformGrid Columns="3" Margin="0,0,0,16">

                    <!-- Windows Version -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE782;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Windows"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding WindowsVersionText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- CPU -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE9A6;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Prozessor"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding CpuText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE9A4;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Arbeitsspeicher"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding RamText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Drive Type -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE711;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Laufwerkstyp"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding DriveTypeText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Free Disk Space -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Freier Speicher"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding FreeDiskText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Autostart Count -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE768;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Autostart-Programme"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding AutostartCountText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Running Processes -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE9D9;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Laufende Prozesse"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding RunningProcessesText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"/>
                        </StackPanel>
                    </Border>

                    <!-- Last Windows Update -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xE895;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Letztes Update"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding LastWindowsUpdateText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Last Malware Scan -->
                    <Border Style="{StaticResource CardStyle}" Margin="6">
                        <StackPanel>
                            <TextBlock Text="&#xEA18;" Style="{StaticResource IconTextBlockStyle}" FontSize="24" HorizontalAlignment="Left" Margin="0,0,0,8"/>
                            <TextBlock Text="Letzter Malware-Scan"
                                       Style="{StaticResource CaptionStyle}"/>
                            <TextBlock Text="{Binding LastMalwareScanText}"
                                       Style="{StaticResource SubheadingStyle}"
                                       FontSize="13"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                </UniformGrid>

                <!-- Recommendation -->
                <Border Style="{StaticResource InfoBoxStyle}"
                        Margin="0,0,0,24"
                        Visibility="{Binding IsEmergencyMode, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel>
                            <TextBlock Text="Empfohlener Einstieg"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource PrimaryBrush}"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding RecommendationText}"
                                       Foreground="#1565C0"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Start Button -->
                <StackPanel Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding StartWizardCommand}"
                            IsEnabled="{Binding CanStartWizard}"
                            HorizontalAlignment="Left"
                            FontSize="16"
                            Padding="32,14"
                            Margin="0,0,10,0">
                        <TextBlock Text="Assistent starten" VerticalAlignment="Center"/>
                    </Button>
                    <Button Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RetrySystemCheckCommand}"
                            HorizontalAlignment="Left"
                            Padding="20,14">
                        <TextBlock Text="Prüfung aktualisieren" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
